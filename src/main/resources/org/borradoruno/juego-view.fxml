<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Ellipse?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.borradoruno.controller.JuegoController"
            style="-fx-background-color: linear-gradient(to bottom, #fca5a5, #f87171);">
    <top>
        <HBox spacing="20" style="-fx-padding: 15; -fx-background-color: rgba(0,0,0,0.2);">
            <Text text="UNO ONLINE 2026" style="-fx-fill: white; -fx-font-weight: bold; -fx-font-size: 20;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="ABANDONAR" onAction="#onAbandonar"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 15; -fx-padding: 5 15;"/>
        </HBox>
    </top>

    <center>
        <StackPane>
            <!-- Centro: pila de descarte y turno -->
            <VBox alignment="CENTER" spacing="20" mouseTransparent="false" pickOnBounds="false">
                <Label fx:id="lblTurnoActual" text="CARGANDO..."
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, black, 2, 0.5, 0, 0);"/>

                <!-- Barra de tiempo -->
                <HBox alignment="CENTER" spacing="10" maxWidth="300">
                    <Label fx:id="lblTiempoRestante" text="--"
                           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white; -fx-min-width: 40;"/>
                    <ProgressBar fx:id="barraTiempo" prefWidth="240" prefHeight="14" progress="1.0"/>
                </HBox>

                <StackPane>
                    <Ellipse radiusX="200" radiusY="140" fill="rgba(255,255,255,0.15)" stroke="white" strokeWidth="2"/>

                    <Label fx:id="lblFlechaArriba" text="▶"
                           StackPane.alignment="TOP_CENTER"
                           style="-fx-font-size: 30; -fx-text-fill: white;"
                           translateY="20"/>
                    <Label fx:id="lblFlechaAbajo" text="◀"
                           StackPane.alignment="BOTTOM_CENTER"
                           style="-fx-font-size: 30; -fx-text-fill: white;"
                           translateY="-20"/>

                    <VBox alignment="CENTER" spacing="15">
                        <Label fx:id="lblSentido" text="SENTIDO HORARIO"
                               style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;"/>
                        <Label fx:id="lblCartaActiva" text="8"
                               style="-fx-alignment: center;"/>
                    </VBox>
                </StackPane>
            </VBox>

            <!-- Esquinas con los otros jugadores (encima del centro para recibir clicks) -->
            <AnchorPane pickOnBounds="false" mouseTransparent="false">
                <HBox fx:id="hboxJugadorIzquierda"
                      AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20"
                      spacing="10" alignment="CENTER_LEFT"
                      visible="false" managed="false"/>

                <HBox fx:id="hboxJugadorDerecha"
                      AnchorPane.topAnchor="20" AnchorPane.rightAnchor="20"
                      spacing="10" alignment="CENTER_RIGHT"
                      visible="false" managed="false"/>

                <Label fx:id="lblJugadorTu"
                       AnchorPane.bottomAnchor="120" AnchorPane.leftAnchor="20"
                       text="Tú"
                       style="-fx-background-color: white; -fx-text-fill: black; -fx-font-weight: bold; -fx-padding: 8 12; -fx-background-radius: 20; -fx-font-size: 14;"
                       visible="false" managed="false"/>

                <HBox fx:id="hboxJugadorAbajoDerecha"
                      AnchorPane.bottomAnchor="120" AnchorPane.rightAnchor="20"
                      spacing="10" alignment="CENTER_RIGHT"
                      visible="false" managed="false"/>
            </AnchorPane>
        </StackPane>
    </center>

    <bottom>
        <VBox spacing="10" style="-fx-padding: 20 30 30 30; -fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 30 30 0 0;">
            <HBox spacing="30" alignment="CENTER">
                <Button text="UNO!" onAction="#onDecirUno"
                        style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 20; -fx-border-color: white; -fx-border-radius: 20;"/>
                <Button fx:id="btnRobar" text="ROBAR" onAction="#onRobarCarta"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 20;"/>
            </HBox>
            <Pane fx:id="paneMano" prefHeight="160" minHeight="160" style="-fx-padding: 10 0;"/>
            <Label text="Haz clic en una carta de tu mano para jugarla"
                   style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12; -fx-font-style: italic;"
                   alignment="CENTER" maxWidth="Infinity"/>
        </VBox>
    </bottom>
</BorderPane>
