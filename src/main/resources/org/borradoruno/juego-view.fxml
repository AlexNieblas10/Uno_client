<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Ellipse?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.borradoruno.controllers.JuegoController">
    <!-- Capa Principal del Juego -->
    <BorderPane fx:id="mainPane" style="-fx-background-color: linear-gradient(to bottom, #fca5a5, #f87171);">
        <top>
            <HBox spacing="20" style="-fx-padding: 15; -fx-background-color: rgba(0,0,0,0.2);">
                <Text text="UNO ONLINE 2026" style="-fx-fill: white; -fx-font-weight: bold; -fx-font-size: 20;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="ABANDONAR" onAction="#onAbandonar" 
                        style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 15; -fx-padding: 5 15;"/>
            </HBox>
        </top>

        <center>
            <VBox alignment="CENTER" spacing="20">
                <Label fx:id="lblTurnoActual" text="CARGANDO..." 
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, black, 2, 0.5, 0, 0);"/>
                
                <StackPane>
                    <Ellipse radiusX="200" radiusY="140" fill="rgba(255,255,255,0.15)" stroke="white" strokeWidth="2"/>
                    <VBox alignment="CENTER" spacing="15">
                        <Label fx:id="lblSentido" text="SENTIDO HORARIO" 
                               style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;"/>
                        <Label fx:id="lblCartaActiva" text="8" 
                               style="-fx-alignment: center;"/>
                    </VBox>
                </StackPane>
            </VBox>
        </center>

        <bottom>
            <VBox spacing="15" style="-fx-padding: 30; -fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 30 30 0 0;">
                <HBox spacing="30" alignment="CENTER">
                    <Button text="UNO!" onAction="#onDecirUno" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 20; -fx-border-color: white; -fx-border-radius: 20;"/>
                    <Button text="ROBAR" onAction="#onRobarCarta" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 20;"/>
                </HBox>
                <ScrollPane fitToHeight="true" vbarPolicy="NEVER" hbarPolicy="AS_NEEDED" 
                            style="-fx-background: transparent; -fx-background-color: transparent;">
                    <HBox fx:id="hboxMano" spacing="15" alignment="CENTER" style="-fx-padding: 10 0;">
                        <!-- Cartas -->
                    </HBox>
                </ScrollPane>
            </VBox>
        </bottom>
    </BorderPane>

    <!-- Overlay de Selección de Color (Comodín) -->
    <VBox fx:id="overlayColor" alignment="CENTER" spacing="20" visible="false" 
          style="-fx-background-color: rgba(0,0,0,0.85);">
        <Text text="ELIJA UN COLOR" style="-fx-fill: white; -fx-font-weight: bold; -fx-font-size: 24;"/>
        <HBox spacing="20" alignment="CENTER">
            <Button text="ROJO" onAction="#onColorSelected" userData="ROJO"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18; -fx-min-width: 120; -fx-min-height: 120; -fx-background-radius: 15;"/>
            <Button text="AZUL" onAction="#onColorSelected" userData="AZUL"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18; -fx-min-width: 120; -fx-min-height: 120; -fx-background-radius: 15;"/>
        </HBox>
        <HBox spacing="20" alignment="CENTER">
            <Button text="VERDE" onAction="#onColorSelected" userData="VERDE"
                    style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18; -fx-min-width: 120; -fx-min-height: 120; -fx-background-radius: 15;"/>
            <Button text="AMARILLO" onAction="#onColorSelected" userData="AMARILLO"
                    style="-fx-background-color: #facc15; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18; -fx-min-width: 120; -fx-min-height: 120; -fx-background-radius: 15;"/>
        </HBox>
        <Button text="CANCELAR" onAction="#onCancelarColor"
                style="-fx-background-color: #4b5563; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30; -fx-background-radius: 10;"/>
    </VBox>

    <!-- Notificación de Turno -->
    <VBox fx:id="overlayTurno" alignment="CENTER" visible="false" mouseTransparent="true">
        <StackPane style="-fx-background-color: rgba(34, 197, 94, 0.9); -fx-padding: 20 40; -fx-background-radius: 20;">
            <Text text="¡ES TU TURNO!" style="-fx-fill: white; -fx-font-weight: bold; -fx-font-size: 32;"/>
        </StackPane>
    </VBox>

    <!-- Toast de Error -->
    <VBox alignment="TOP_CENTER" mouseTransparent="true" pickOnBounds="false">
        <padding>
            <Insets top="80"/>
        </padding>
        <Label fx:id="lblError" visible="false"
               style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 14; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 10, 0, 0, 5);"/>
    </VBox>
</StackPane>