<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.borradoruno.controller.IniciarPartidaController"
      style="-fx-background-color: #f8c8cb;">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10;" maxWidth="500">
        <Text text="Iniciar partida" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
        <Text text="Confirma para repartir cartas y comenzar el juego" style="-fx-fill: #6b7280;"/>

        <Label text="Código de sala" style="-fx-padding: 15 0 0 0;"/>
        <Label fx:id="lblCodigoSala" text="--" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1d4ed8;"/>

        <Label text="Jugadores" style="-fx-padding: 10 0 0 0;"/>
        <Label fx:id="lblContadorJugadores" text="0/4" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

        <Label text="Estado de listos" style="-fx-padding: 10 0 0 0;"/>
        <Label fx:id="lblEstadoListos" text="0 de 0 listos" style="-fx-font-size: 14; -fx-text-fill: #22c55e; -fx-font-weight: bold;"/>
    </VBox>

    <Button fx:id="btnConfirmar" text="INICIAR PARTIDA" onAction="#onConfirmarInicio"
            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 300; -fx-min-height: 45; -fx-background-radius: 8; -fx-font-size: 14;"/>
    <Button fx:id="btnCancelar" text="CANCELAR" onAction="#onCancelar"
            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 300; -fx-min-height: 45; -fx-background-radius: 8; -fx-font-size: 14;"/>

    <Text text="© 2026 Uno Online 1.12v" style="-fx-fill: gray;"/>
</VBox>
