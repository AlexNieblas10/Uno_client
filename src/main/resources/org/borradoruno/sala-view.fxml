<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<HBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.borradoruno.controller.SalaController"
      style="-fx-background-color: #f8c8cb;">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!-- Configuración (Solo visible para anfitrión) -->
    <VBox fx:id="vboxConfig" spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" prefWidth="300">
        <Text text="Configurar partida" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
        <Label text="Jugadores máximos"/>
        <HBox spacing="10">
            <Button fx:id="btnMax2" text="2" onAction="#onSetMax2" style="-fx-min-width: 40; -fx-background-radius: 5;"/>
            <Button fx:id="btnMax3" text="3" onAction="#onSetMax3" style="-fx-min-width: 40; -fx-background-radius: 5;"/>
            <Button fx:id="btnMax4" text="4" onAction="#onSetMax4" style="-fx-min-width: 40; -fx-background-radius: 5;"/>
        </HBox>
        <Label text="Código de sala"/>
        <TextField fx:id="txtCodigoSala" editable="false" style="-fx-background-color: #f3f4f6;"/>
        <Button text="CANCELAR" onAction="#onAbandonar" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-min-width: 200; -fx-background-radius: 10;"/>
    </VBox>

    <!-- Lista de Jugadores -->
    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" prefWidth="300">
        <HBox spacing="10">
            <Text text="Jugadores en la sala" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
            <Label fx:id="lblContador" text="(1/4)"/>
        </HBox>
        
        <VBox fx:id="vboxJugadores" spacing="5">
            <!-- Los jugadores se cargarán dinámicamente -->
        </VBox>
        
        <Label fx:id="lblEstado" text="esperando a los jugadores..." style="-fx-text-fill: gray;"/>
        <Button fx:id="btnAccion" text="INICIAR PARTIDA" onAction="#onAccionPrincipal"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 250; -fx-background-radius: 10;"/>
    </VBox>
</HBox>