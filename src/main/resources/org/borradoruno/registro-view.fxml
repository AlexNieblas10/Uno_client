<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.borradoruno.controller.RegistroController"
      style="-fx-background-color: #f8c8cb;">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 10;" maxWidth="400">
        <Text text="UNO Online" style="-fx-font-size: 28; -fx-font-weight: bold;"/>

        <Label text="Tu nombre:"/>
        <TextField fx:id="txtNombre" promptText="Ingresa tu nombre" maxWidth="300"/>

        <Label text="Elige tu avatar:"/>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Button fx:id="btnAvatarAzul"     onAction="#onAvatarAzul"/>
            <Button fx:id="btnAvatarAmarillo" onAction="#onAvatarAmarillo"/>
            <Button fx:id="btnAvatarRojo"     onAction="#onAvatarRojo"/>
            <Button fx:id="btnAvatarVerde"    onAction="#onAvatarVerde"/>
        </HBox>

        <Button text="CREAR PARTIDA" onAction="#onCrearPartida"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 260; -fx-min-height: 45; -fx-background-radius: 8; -fx-font-size: 14;"/>
        <Button text="UNIRSE A PARTIDA" onAction="#onUnirsePartida"
                style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 260; -fx-min-height: 45; -fx-background-radius: 8; -fx-font-size: 14;"/>
    </VBox>

    <Text text="© 2026 Uno Online 1.12v" style="-fx-fill: gray;"/>
</VBox>
