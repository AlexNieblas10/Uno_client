<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.borradoruno.controller.RegistroController"
      style="-fx-background-color: #f8c8cb;">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10;" maxWidth="500">
        <Text text="Registrar usuario" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
        <Text text="Personaliza tu perfil antes de jugar" style="-fx-fill: #6b7280;"/>

        <Label text="Apodo de Jugador" style="-fx-padding: 10 0 0 0;"/>
        <TextField fx:id="txtApodo" promptText="Tu nombre aquí"/>

        <Label text="Elige tu Avatar" style="-fx-padding: 15 0 0 0;"/>
        <HBox spacing="10" fx:id="hboxAvatares">
            <Button fx:id="btnAvatarAzul" onAction="#onSeleccionarAvatarAzul"
                    style="-fx-background-color: #3b82f6; -fx-min-width: 50; -fx-min-height: 50; -fx-background-radius: 8;"/>
            <Button fx:id="btnAvatarAmarillo" onAction="#onSeleccionarAvatarAmarillo"
                    style="-fx-background-color: #facc15; -fx-min-width: 50; -fx-min-height: 50; -fx-background-radius: 8;"/>
            <Button fx:id="btnAvatarRojo" onAction="#onSeleccionarAvatarRojo"
                    style="-fx-background-color: #ef4444; -fx-min-width: 50; -fx-min-height: 50; -fx-background-radius: 8;"/>
            <Button fx:id="btnAvatarVerde" onAction="#onSeleccionarAvatarVerde"
                    style="-fx-background-color: #22c55e; -fx-min-width: 50; -fx-min-height: 50; -fx-background-radius: 8;"/>
        </HBox>
    </VBox>

    <Button text="UNIRSE A PARTIDA" onAction="#onUnirsePartida"
            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 300; -fx-min-height: 45; -fx-background-radius: 8; -fx-font-size: 14;"/>
    <Button text="CREAR PARTIDA" onAction="#onCrearPartida"
            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 300; -fx-min-height: 45; -fx-background-radius: 8; -fx-font-size: 14;"/>

    <Text text="© 2026 Uno Online 1.12v" style="-fx-fill: gray;"/>
</VBox>
