<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<!-- STUB: Caso de uso "Registrar Jugador" disponible en rama feature/registrar-jugador -->
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.borradoruno.controller.RegistroController"
      style="-fx-background-color: #f8c8cb;">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 10;" maxWidth="500">
        <Text text="UNO Online" style="-fx-font-size: 28; -fx-font-weight: bold;"/>
        <Text text="Registro de jugador no disponible en esta rama."
              style="-fx-fill: #6b7280; -fx-font-size: 14;"/>
        <Text text="Ver implementación completa en:"
              style="-fx-fill: #374151;"/>
        <Text text="feature/registrar-jugador"
              style="-fx-fill: #1d4ed8; -fx-font-weight: bold; -fx-font-size: 13;"/>

        <Button text="CREAR PARTIDA" onAction="#onCrearPartida"
                style="-fx-background-color: #d1d5db; -fx-text-fill: #9ca3af; -fx-font-weight: bold; -fx-min-width: 260; -fx-min-height: 45; -fx-background-radius: 8; -fx-font-size: 14;"
                disable="true"/>
        <Button text="UNIRSE A PARTIDA" onAction="#onUnirsePartida"
                style="-fx-background-color: #d1d5db; -fx-text-fill: #9ca3af; -fx-font-weight: bold; -fx-min-width: 260; -fx-min-height: 45; -fx-background-radius: 8; -fx-font-size: 14;"
                disable="true"/>
    </VBox>

    <Text text="© 2026 Uno Online 1.12v" style="-fx-fill: gray;"/>
</VBox>
